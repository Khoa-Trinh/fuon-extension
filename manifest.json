{
  "manifest_version": 3,
  "name": "YT-Audio-Harvest",
  "version": "1.0",
  "permissions": ["storage", "scripting", "offscreen"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["bridge.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
